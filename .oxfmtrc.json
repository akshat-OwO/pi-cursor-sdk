{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"tabWidth": 2,
	"printWidth": 100,
	"singleQuote": false,
	"semi": true,
	"trailingComma": "all",
	"ignorePatterns": [
		"dist/**",
		"coverage/**",
		"node_modules/**",
		"pnpm-lock.yaml",
		"src/discovery/cursor-fallback-models.generated.ts"
	]
}

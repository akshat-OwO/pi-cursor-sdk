{
	"lsp": {
		"oxlint": {
			"initialization_options": {
				"settings": {
					"configPath": ".oxlintrc.json",
					"disableNestedConfig": false,
					"fixKind": "safe_fix",
					"run": "onType",
					"unusedDisableDirectives": "deny"
				}
			}
		},
		"oxfmt": {
			"initialization_options": {
				"settings": {
					"fmt.configPath": ".oxfmtrc.json",
					"run": "onSave"
				}
			}
		}
	},
	"languages": {
		"JavaScript": {
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"language_server": {
						"name": "oxfmt"
					}
				},
				{
					"code_action": "source.fixAll.oxc"
				}
			]
		},
		"TypeScript": {
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		},
		"TSX": {
			"format_on_save": "on",
			"prettier": {
				"allowed": false
			},
			"formatter": [
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		},
		"JSONC": {
			"format_on_save": "on",
			"formatter": [
				{
					"language_server": {
						"name": "oxfmt"
					}
				}
			]
		}
	}
}
